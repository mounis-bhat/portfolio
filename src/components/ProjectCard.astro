---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'works'>;
}

const { project } = Astro.props;
const { slug, data } = project;
---

<a href={`/works/${slug}`} class="project-card">
  {
    data.image ? (
      <div class="project-card__image">
        <img
          src={data.image}
          alt={data.title}
          loading="lazy"
          width="600"
          height="338"
          transition:name={`project-image-${slug}`}
        />
      </div>
    ) : (
      <div class="project-card__image project-card__image--placeholder">
        <span class="project-card__placeholder-icon" aria-hidden="true">⬡</span>
      </div>
    )
  }

  <div class="project-card__body">
    <div class="project-card__meta">
      {data.year && <span class="project-card__year">{data.year}</span>}
      {
        data.tags?.slice(0, 3).map((tag) => (
          <span class="project-card__tag">{tag}</span>
        ))
      }
    </div>

    <h3 class="project-card__title" transition:name={`project-title-${slug}`}>
      {data.title}
    </h3>

    <p class="project-card__desc">{data.description}</p>
  </div>

  <span class="project-card__arrow" aria-hidden="true">→</span>
</a>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    background-color: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    position: relative;
    transition:
      border-color var(--dur-base) var(--ease-out),
      box-shadow var(--dur-base) var(--ease-out),
      transform var(--dur-base) var(--ease-out);
  }

  /* Teal gradient shimmer — slides in from top-left on hover */
  .project-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(136, 204, 202, 0.08) 0%,
      transparent 55%
    );
    opacity: 0;
    transition: opacity var(--dur-base) var(--ease-out);
    pointer-events: none;
    z-index: 0;
  }

  .project-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }

  .project-card:hover::before {
    opacity: 1;
  }

  /* Image area */
  .project-card__image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background-color: var(--bg-elevated);
    flex-shrink: 0;
  }

  .project-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur-slow) var(--ease-out);
  }

  .project-card:hover .project-card__image img {
    transform: scale(1.05);
  }

  /* Placeholder for projects without an image */
  .project-card__image--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .project-card__placeholder-icon {
    font-size: 2.5rem;
    color: var(--border-strong);
    line-height: 1;
  }

  /* Body */
  .project-card__body {
    padding: var(--space-5);
    flex: 1;
  }

  .project-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
    flex-wrap: wrap;
  }

  .project-card__year {
    font-size: var(--text-xs);
    color: var(--text-faint);
    font-variant-numeric: tabular-nums;
    font-weight: 500;
  }

  .project-card__tag {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--text-faint);
    background-color: var(--tag-bg);
    padding: 2px var(--space-2);
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
  }

  .project-card__title {
    font-family: var(--font-display);
    font-size: var(--text-md);
    font-weight: 400;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-2);
    color: var(--text);
    line-height: 1.3;
  }

  .project-card__desc {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.65;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Arrow */
  .project-card__arrow {
    position: absolute;
    bottom: var(--space-5);
    right: var(--space-5);
    font-size: var(--text-sm);
    color: var(--text-faint);
    opacity: 0;
    transform: translateX(-6px);
    transition:
      opacity var(--dur-fast) var(--ease-out),
      transform var(--dur-fast) var(--ease-out);
  }

  .project-card:hover .project-card__arrow {
    opacity: 1;
    transform: translateX(0);
  }
</style>
